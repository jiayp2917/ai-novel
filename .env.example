# ai-novel 环境变量样例。复制为 .env 后按需填写。
# 后端由 backend/app/core/config.py (pydantic-settings) 读取；前端 VITE_* 由 Vite 在 build 时注入。

# ===== 后端：路径与运行时 =====
# APP_DB_PATH=runtime/app.db
CONTENT_ROOT=content
# RUNTIME_ROOT=runtime
# APP_RUNTIME_ROOT=
# WORKSPACE_RUNTIME_ROOT_OVERRIDE=

# ===== 后端：成本与并发 =====
LOW_COST_MODE=false
ENABLE_MODEL_CONCURRENCY=false
MODEL_MAX_CONCURRENCY=2
WRITER_MAX_CONCURRENCY=2
REVIEWER_MAX_CONCURRENCY=1
MEMORY_MAX_CONCURRENCY=1
PROVIDER_MAX_CONCURRENCY=2
MODEL_TIMEOUT_SECONDS=300
DAILY_MAX_MODEL_CALLS=200
DAILY_MAX_ESTIMATED_COST=20.0
MAX_INPUT_CHARS_PER_CALL=60000
MAX_OUTPUT_TOKENS_PER_CALL=12000

# ===== 后端：模型与安全 =====
DEFAULT_MODEL_PROVIDER=agnes
# 对外暴露后端（非 127.0.0.1）时必须设置；前端可用 VITE_ADMIN_API_TOKEN 传入同一个 token
# ADMIN_API_TOKEN=
# ENABLE_TEST_SUPPORT=false            # 仅 Playwright E2E 用，生产环境保持 false
# ALLOW_PIPELINE_DIRECT_PUBLISH=false  # 允许 pipeline 直接写回正文，生产环境保持 false

# ===== 后端：思考模式（disabled / enabled） =====
KIMI_THINKING_MODE=disabled
GLM_THINKING_MODE=disabled

# ===== 模型供应商密钥（至少配置一个供应商的 key） =====
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_API_KEY=
DEEPSEEK_API_KEY=
KIMI_API_KEY=
QWEN_API_KEY=
GLM_API_KEY=

# ===== 前端（Vite 构建时注入，前端代码用 import.meta.env 读取） =====
# VITE_API_BASE_URL=http://127.0.0.1:8000
# VITE_ADMIN_API_TOKEN=                # 与后端 ADMIN_API_TOKEN 一致，仅对外暴露时需要
